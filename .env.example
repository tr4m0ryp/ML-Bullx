# Helius API Keys - Add multiple keys for rate limit distribution
# Get keys at https://dev.helius.xyz/
HELIUS_API_KEY_1=your_helius_key_here
HELIUS_API_KEY_2=your_helius_key_here
# Add more as needed: HELIUS_API_KEY_3, HELIUS_API_KEY_4, etc.

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=solana_pipeline
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# Primary RPC endpoint (fallback)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Helius base URL
HELIUS_BASE_URL=https://rpc.helius.xyz
